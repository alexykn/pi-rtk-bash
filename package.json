{
  "name": "pi-rtk-bash",
  "version": "0.1.1",
  "type": "module",
  "description": "RTK-backed rtk_bash tool for Pi one-shot shell commands.",
  "main": "./src/index.ts",
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "pi-package",
    "pi-extension",
    "rtk",
    "bash",
    "shell",
    "token-saving",
    "coding-agent"
  ],
  "license": "MIT",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck",
    "prepack": "npm run check"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.75.5",
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@earendil-works/pi-tui": "^0.75.5",
    "@types/node": "^25.9.1",
    "typebox": "^1.1.38",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexykn/pi-rtk-bash.git"
  },
  "bugs": {
    "url": "https://github.com/alexykn/pi-rtk-bash/issues"
  },
  "homepage": "https://github.com/alexykn/pi-rtk-bash#readme"
}
